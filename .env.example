APP_HOST=127.0.0.1
APP_PORT=3000
DATA_ROOT=./data
RETENTION_DAYS=30
RETENTION_TZ=Asia/Seoul
MAX_INPUT_ROWS=5000
MAX_INPUT_BYTES=20971520

# 에이전트 외부 연구는 기본 비활성입니다.
# true로 바꾸고 아래 공식 API 인증정보를 입력해야 LIVE 모드가 작동합니다.
ALLOW_EXTERNAL_RESEARCH=false

# KAMIS 공식 가격 Open API
KAMIS_CERT_KEY=
KAMIS_CERT_ID=

# NAVER Search Trend / NAVER API HUB
# 2026년 API HUB 이관을 고려해 endpoint와 헤더명을 설정식으로 둡니다.
NAVER_TREND_ENDPOINT=
NAVER_TREND_CLIENT_ID=
NAVER_TREND_CLIENT_SECRET=
NAVER_TREND_ID_HEADER=X-Naver-Client-Id
NAVER_TREND_SECRET_HEADER=X-Naver-Client-Secret

# 식품안전나라 Open API
FOOD_SAFETY_KEY=
FOOD_SAFETY_SERVICE_ID=
FOOD_SAFETY_QUERY_FIELD=
