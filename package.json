{
  "name": "commerce-diagnostic-hub",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22.13.0" },
  "scripts": {
    "diagnose": "node --env-file-if-exists=.env --experimental-strip-types apps/cli/src/index.ts",
    "dev": "node --env-file-if-exists=.env --experimental-strip-types --watch apps/local-web/src/server.ts",
    "start": "node --env-file-if-exists=.env --experimental-strip-types apps/local-web/src/server.ts",
    "test": "node --experimental-strip-types --test packages/*/test/*.test.ts apps/local-web/test/*.test.ts",
    "test:core": "node --experimental-strip-types --test packages/core/test/*.test.ts",
    "test:agent": "node --experimental-strip-types --test packages/agent/test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "node --experimental-strip-types scripts/check-boundaries.ts"
  },
  "dependencies": {
    "sanitize-html": "2.17.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/sanitize-html": "2.16.1",
    "typescript": "6.0.3"
  }
}
